# ─── LLM provider ────────────────────────────────────────────────────────────
# Which backend generates the arguments: anthropic | openai | ollama | fake
# ("fake" is a deterministic offline provider for testing the plumbing.)
AW_LLM_PROVIDER=anthropic

# Model id. Defaults per provider: anthropic=claude-opus-4-8, openai=gpt-4o-mini,
# ollama=llama3.1
#AW_LLM_MODEL=claude-opus-4-8

# Optional: a cheaper model for the analysis call (RoleRouter). The analyzer
# feeds the generator — a weak analyzer produces sloppy tone/weak-point/fallacy
# data that degrades the strong model's output. Use a structured-output-proficient
# model (Haiku-class minimum, never a tiny local model). Leave unset to use one
# strong model for both roles (recommended default).
#AW_MODEL_ANALYZER=claude-haiku-4-5

ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
# OpenAI-compatible endpoint used when AW_LLM_PROVIDER=ollama
#AW_OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Discord ─────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
# IMPORTANT: you must also enable the "Message Content Intent" toggle under
# Bot → Privileged Gateway Intents, or the bot will see empty messages.
DISCORD_BOT_TOKEN=

# Comma-separated guild ids for instant slash-command sync while developing.
# Leave empty for global sync (takes up to ~1h to propagate).
#AW_DISCORD_DEV_GUILD_IDS=123456789012345678

# ─── Voice profile (sound like you) ──────────────────────────────────────────
# Path to a markdown file with your style notes + sample messages you wrote,
# so replies read like YOU typed them. Applies to the desktop helper, /argue
# suggestions and the REPL — never to auto-combat (the bot argues as itself).
# Unset/blank = off. Set to a missing file = startup error (loud misconfig).
# Start from: cp voice.example.md voice.md
#AW_VOICE_PROFILE=voice.md

# ─── Argument engine ─────────────────────────────────────────────────────────
# mild | medium | savage — caps how mean the bot is allowed to get.
# mild forbids the Savage persona and non-SAFE candidates; medium allows up to
# SPICY; savage allows everything including NUCLEAR candidates.
AW_SPICE_LEVEL=medium

# ─── Desktop helper (python -m argumentwinner --desktop) ─────────────────────
# Works in ANY app: copy the message you're arguing with, press the hotkey, and
# the comeback lands on your clipboard ready to paste. No account automation.
# Hotkey format is pynput's: <ctrl>, <alt>, <cmd>, <shift> + a key.
AW_DESKTOP_HOTKEY=<ctrl>+<alt>+w
# Cycle to the next candidate without regenerating.
AW_DESKTOP_CYCLE_HOTKEY=<ctrl>+<alt>+e
# Optional: always argue in one style (logician|savage|diplomat|socratic).
# Leave unset to let the engine pick adaptively.
#AW_DESKTOP_PERSONA=savage

# ─── Auto-combat guardrails ──────────────────────────────────────────────────
AW_COMBAT_COOLDOWN_SECONDS=20
AW_COMBAT_MAX_REPLIES=12
AW_COMBAT_DEBOUNCE_SECONDS=2.5
# How many recent messages are fetched to build argument context each turn.
AW_MAX_CONTEXT_TURNS=24
AW_SESSION_TTL_MINUTES=60
# Never enable this unless you enjoy infinite bot-vs-bot loops.
AW_REPLY_TO_BOTS=false
